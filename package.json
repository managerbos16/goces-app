{
  "name": "goces-app",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build:css": "node build-css.js",
    "watch:css": "node build-css.js --watch",
    "build:js": "node build-js.js",
    "watch:js": "node build-js.js --watch",
    "build": "npm-run-all build:css build:js",
    "dev": "npm-run-all --parallel watch:css watch:js"
  },
  "devDependencies": {
    "chokidar": "^5.0.0",
    "esbuild": "^0.28.1",
    "fast-glob": "^3.3.3",
    "npm-run-all": "^4.1.5"
  }
}
